{
  "$schema": "https://json-schema.org/draft/2019-09/schema#",
  "title": "event",
  "description": "Runfile event schemas. Source: src/event.ts (Zod). Do not edit by hand.",
  "$ref": "#/definitions/_RunfileBundle",
  "definitions": {
    "RunfileRun": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "tenant_id": {
          "type": "string",
          "pattern": "^tnt_[0-9a-z]{12}$"
        },
        "agent_identity": {
          "type": "string",
          "pattern": "^did:[a-z][a-z0-9]*:[A-Za-z0-9._:-]+$"
        },
        "conversation_id": {
          "type": "string",
          "maxLength": 256
        },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "active",
            "awaiting_human",
            "awaiting_webhook",
            "awaiting_schedule",
            "ended"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "outcome": {
          "anyOf": [
            {
              "type": "string",
              "enum": [
                "success",
                "failure",
                "incomplete",
                "abandoned"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "delegated_from": {
          "$ref": "#/definitions/RunReference"
        },
        "handed_off_from": {
          "$ref": "#/definitions/RunReference"
        },
        "scheduled_from": {
          "$ref": "#/definitions/RunReference"
        },
        "invoked_by": {
          "$ref": "#/definitions/RunReference"
        },
        "continued_from": {
          "$ref": "#/definitions/RunReference"
        },
        "active_duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "suspension_intervals": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SuspensionInterval"
          },
          "maxItems": 100
        },
        "environment": {
          "type": "string",
          "enum": [
            "production",
            "staging",
            "development"
          ]
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 128
          },
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]{0,31}$"
          },
          "maxProperties": 16
        },
        "redaction_policy_version": {
          "$ref": "#/definitions/RunfileRun/properties/schema_version"
        },
        "regulatory_scope_version": {
          "$ref": "#/definitions/RunfileRun/properties/schema_version"
        },
        "sdk_at_start": {
          "$ref": "#/definitions/SdkMetadata"
        },
        "merkle_inclusions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MerkleInclusion"
          }
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "tenant_id",
        "agent_identity",
        "lifecycle_state",
        "started_at",
        "redaction_policy_version"
      ],
      "additionalProperties": false
    },
    "RunfileEvent": {
      "type": "object",
      "properties": {
        "schema_version": {
          "$ref": "#/definitions/RunfileRun/properties/schema_version"
        },
        "event_id": {
          "type": "string",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "tenant_id": {
          "$ref": "#/definitions/RunfileRun/properties/tenant_id"
        },
        "run_id": {
          "$ref": "#/definitions/RunfileRun/properties/run_id"
        },
        "parent_event_id": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunfileEvent/properties/event_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "parallel_group_id": {
          "type": "string",
          "pattern": "^pg_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "segment_index": {
          "type": "integer",
          "minimum": 0,
          "description": "Which execution segment of the run this event belongs to. 0 for the initial segment; incremented each time the run resumes after a suspension. With local_seq this gives a total order within a segment: (run_id, segment_index, local_seq)."
        },
        "local_seq": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonic capture counter assigned by the SDK within a single process segment, starting at 0. Authoritative ordering for the hash chain within a segment; resets to 0 at the start of each segment. A gap (e.g. 0,1,3) means an event was lost (sequence_gap anomaly)."
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "wall_clock_source": {
          "type": "string",
          "enum": [
            "aws_time_sync",
            "ntp",
            "host_system",
            "unknown"
          ]
        },
        "sdk": {
          "$ref": "#/definitions/SdkMetadata"
        },
        "actor": {
          "$ref": "#/definitions/Actor"
        },
        "action": {
          "$ref": "#/definitions/Action"
        },
        "subject": {
          "$ref": "#/definitions/Subject"
        },
        "model_ref": {
          "$ref": "#/definitions/ModelRef"
        },
        "decision": {
          "$ref": "#/definitions/Decision"
        },
        "suspension_details": {
          "$ref": "#/definitions/SuspensionDetails"
        },
        "resume_details": {
          "$ref": "#/definitions/ResumeDetails"
        },
        "delegation_details": {
          "$ref": "#/definitions/DelegationDetails"
        },
        "handoff_details": {
          "$ref": "#/definitions/HandoffDetails"
        },
        "payload_ref": {
          "$ref": "#/definitions/PayloadRef"
        },
        "otel_attributes": {
          "$ref": "#/definitions/OtelAttributes"
        },
        "redaction_policy_version": {
          "$ref": "#/definitions/RunfileRun/properties/schema_version"
        },
        "regulatory_scope_version": {
          "$ref": "#/definitions/RunfileRun/properties/schema_version"
        },
        "anomaly_flags": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AnomalyFlag"
          },
          "maxItems": 32
        },
        "environment": {
          "$ref": "#/definitions/RunfileRun/properties/environment"
        },
        "labels": {
          "$ref": "#/definitions/RunfileRun/properties/labels"
        },
        "prev_event_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "event_hash": {
          "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
        },
        "merkle_inclusion": {
          "$ref": "#/definitions/MerkleInclusion"
        }
      },
      "required": [
        "schema_version",
        "event_id",
        "tenant_id",
        "run_id",
        "parent_event_id",
        "segment_index",
        "local_seq",
        "captured_at",
        "received_at",
        "wall_clock_source",
        "sdk",
        "actor",
        "action",
        "redaction_policy_version",
        "prev_event_hash",
        "event_hash"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "llm_call"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "model_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "decision"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "decision"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "run_suspend"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "suspension_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "run_resume"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "resume_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "delegate"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "delegation_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "handoff"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "handoff_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "actor": {
                "properties": {
                  "type": {
                    "const": "agent"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "actor": {
                "required": [
                  "agent_identity"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "actor": {
                "properties": {
                  "type": {
                    "const": "tool"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "actor": {
                "required": [
                  "tool_id",
                  "tool_version_hash"
                ]
              }
            }
          }
        }
      ]
    },
    "Actor": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "tool",
            "system"
          ]
        },
        "agent_identity": {
          "$ref": "#/definitions/RunfileRun/properties/agent_identity",
          "description": "DID-format identifier of the agent. Required when type=agent."
        },
        "human_principal": {
          "type": "string",
          "pattern": "^tok_[A-Za-z0-9]{16,64}$",
          "description": "Vault token identifying the human principal."
        },
        "delegation_chain": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 16,
          "default": []
        },
        "tool_id": {
          "type": "string",
          "pattern": "^tool:[a-z0-9_.-]+:[a-z0-9_.-]+$"
        },
        "tool_version_hash": {
          "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
        }
      },
      "required": [
        "type"
      ],
      "additionalProperties": false
    },
    "Action": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "graph_node_enter",
            "graph_node_exit",
            "llm_call",
            "llm_call_chunk",
            "tool_call",
            "tool_result",
            "tool_approval_requested",
            "tool_approval_granted",
            "tool_approval_denied",
            "state_read",
            "state_write",
            "decision",
            "run_create",
            "run_end",
            "run_suspend",
            "run_resume",
            "run_abandon",
            "delegate",
            "handoff",
            "schedule_task",
            "parallel_group_open",
            "parallel_group_close",
            "human_approval",
            "human_input",
            "policy_check",
            "anomaly_flag",
            "sdk_diagnostic"
          ]
        },
        "name": {
          "type": "string",
          "maxLength": 256
        },
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "failure",
            "partial",
            "timeout",
            "cancelled"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "kind",
        "name"
      ],
      "additionalProperties": false
    },
    "Subject": {
      "type": "object",
      "properties": {
        "resource_urn": {
          "type": "string",
          "pattern": "^urn:[a-z0-9][a-z0-9-]{0,31}:.+$",
          "maxLength": 512
        },
        "data_classification": {
          "type": "string",
          "enum": [
            "public",
            "internal",
            "confidential",
            "pii",
            "phi",
            "pci",
            "fci",
            "audit_of_audit"
          ]
        },
        "regulatory_tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "maxItems": 32
        }
      },
      "additionalProperties": false
    },
    "ModelRef": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai",
            "google",
            "aws_bedrock",
            "azure_openai",
            "ollama",
            "self_hosted",
            "other"
          ]
        },
        "model_id": {
          "type": "string",
          "maxLength": 128
        },
        "model_version_hash": {
          "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
        },
        "system_prompt_hash": {
          "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
        },
        "tools_hash": {
          "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
        },
        "input_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "output_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "streaming": {
          "type": "boolean"
        }
      },
      "required": [
        "provider",
        "model_id"
      ],
      "additionalProperties": false
    },
    "Decision": {
      "type": "object",
      "properties": {
        "outcome": {
          "type": "string",
          "enum": [
            "approved",
            "denied",
            "escalated",
            "deferred",
            "no_action",
            "custom"
          ]
        },
        "outcome_label": {
          "type": "string",
          "maxLength": 64
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "human_in_the_loop": {
          "type": "boolean"
        },
        "policy_thresholds_crossed": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 64
          },
          "maxItems": 16
        },
        "reversed_by_event": {
          "$ref": "#/definitions/RunfileEvent/properties/event_id"
        }
      },
      "required": [
        "outcome"
      ],
      "additionalProperties": false
    },
    "SuspensionDetails": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "awaiting_human_approval",
            "awaiting_human_input",
            "awaiting_webhook",
            "awaiting_schedule",
            "awaiting_external_system",
            "awaiting_subagent",
            "other"
          ]
        },
        "expected_resumer": {
          "type": "string"
        },
        "expected_resume_by": {
          "type": "string",
          "format": "date-time"
        },
        "detection_source": {
          "type": "string",
          "enum": [
            "framework_inferred",
            "customer_explicit",
            "derived"
          ]
        },
        "framework_signal": {
          "type": "object",
          "properties": {
            "framework": {
              "type": "string",
              "enum": [
                "langgraph",
                "openai_agents",
                "claude_agent_sdk",
                "vercel_ai_sdk",
                "mcp",
                "manual",
                "otel"
              ]
            },
            "signal_name": {
              "type": "string",
              "maxLength": 128
            },
            "signal_payload_hash": {
              "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "reason"
      ],
      "additionalProperties": false
    },
    "ResumeDetails": {
      "type": "object",
      "properties": {
        "triggered_by": {
          "type": "string",
          "enum": [
            "human_approval_granted",
            "human_input_received",
            "webhook_received",
            "schedule_fired",
            "external_system_response",
            "subagent_completed",
            "manual_resume",
            "other"
          ]
        },
        "resumer_principal": {
          "$ref": "#/definitions/Actor/properties/human_principal"
        },
        "suspension_duration_seconds": {
          "type": "integer",
          "minimum": 0
        },
        "suspension_started_event_id": {
          "$ref": "#/definitions/RunfileEvent/properties/event_id"
        }
      },
      "required": [
        "triggered_by"
      ],
      "additionalProperties": false
    },
    "DelegationDetails": {
      "type": "object",
      "properties": {
        "delegated_run_id": {
          "$ref": "#/definitions/RunfileRun/properties/run_id"
        },
        "delegated_agent_identity": {
          "$ref": "#/definitions/RunfileRun/properties/agent_identity"
        },
        "wait_for_completion": {
          "type": "boolean"
        },
        "framework_signal": {
          "type": "string",
          "enum": [
            "langgraph_subgraph",
            "openai_agents_as_tool",
            "claude_agent_sdk_subagent",
            "manual",
            "other"
          ]
        }
      },
      "required": [
        "delegated_run_id",
        "delegated_agent_identity"
      ],
      "additionalProperties": false
    },
    "HandoffDetails": {
      "type": "object",
      "properties": {
        "target_run_id": {
          "$ref": "#/definitions/RunfileRun/properties/run_id"
        },
        "target_agent_identity": {
          "$ref": "#/definitions/RunfileRun/properties/agent_identity"
        },
        "handoff_reason": {
          "type": "string",
          "maxLength": 256
        },
        "framework_signal": {
          "type": "string",
          "enum": [
            "openai_agents_handoff",
            "langgraph_explicit",
            "manual",
            "other"
          ]
        }
      },
      "required": [
        "target_run_id",
        "target_agent_identity"
      ],
      "additionalProperties": false
    },
    "SuspensionInterval": {
      "type": "object",
      "properties": {
        "started": {
          "type": "string",
          "format": "date-time"
        },
        "ended": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "null"
            }
          ]
        },
        "reason": {
          "$ref": "#/definitions/SuspensionDetails/properties/reason"
        },
        "trigger_event_id": {
          "$ref": "#/definitions/RunfileEvent/properties/event_id"
        },
        "resume_event_id": {
          "$ref": "#/definitions/RunfileEvent/properties/event_id"
        }
      },
      "required": [
        "started",
        "reason",
        "trigger_event_id"
      ],
      "additionalProperties": false
    },
    "PayloadRef": {
      "type": "object",
      "properties": {
        "s3_uri": {
          "type": "string",
          "pattern": "^s3:\\/\\/[a-z0-9.-]{3,63}\\/.+$",
          "maxLength": 1024
        },
        "sha256": {
          "$ref": "#/definitions/RunfileEvent/properties/prev_event_hash"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 67108864
        },
        "encryption": {
          "$ref": "#/definitions/PayloadEncryption"
        },
        "content_type": {
          "type": "string",
          "enum": [
            "application/json",
            "text/plain",
            "application/vnd.runfile.llm-request+json",
            "application/vnd.runfile.llm-response+json",
            "application/vnd.runfile.tool-call+json",
            "application/vnd.runfile.tool-result+json",
            "application/vnd.runfile.state-snapshot+json",
            "application/vnd.runfile.framework-signal+json"
          ]
        },
        "redaction_applied": {
          "$ref": "#/definitions/RedactionApplied"
        }
      },
      "required": [
        "s3_uri",
        "sha256",
        "size_bytes",
        "encryption"
      ],
      "additionalProperties": false
    },
    "PayloadEncryption": {
      "type": "object",
      "properties": {
        "algorithm": {
          "type": "string",
          "const": "aes-256-gcm"
        },
        "data_key_wrapped": {
          "type": "string",
          "maxLength": 4096
        },
        "key_id": {
          "type": "string",
          "maxLength": 256
        },
        "nonce": {
          "type": "string",
          "maxLength": 64
        }
      },
      "required": [
        "algorithm",
        "data_key_wrapped",
        "nonce"
      ],
      "additionalProperties": false
    },
    "RedactionApplied": {
      "type": "object",
      "properties": {
        "redacted_classes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 32
        },
        "tokenized_classes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "maxItems": 32
        },
        "classifier_version": {
          "$ref": "#/definitions/RunfileRun/properties/schema_version"
        }
      },
      "additionalProperties": false
    },
    "OtelAttributes": {
      "type": "object",
      "properties": {
        "gen_ai_system": {
          "type": "string"
        },
        "gen_ai_operation_name": {
          "type": "string"
        },
        "gen_ai_provider_name": {
          "type": "string"
        },
        "gen_ai_request_model": {
          "type": "string"
        },
        "gen_ai_response_model": {
          "type": "string"
        },
        "gen_ai_request_temperature": {
          "type": "number"
        },
        "gen_ai_request_top_p": {
          "type": "number"
        },
        "gen_ai_request_max_tokens": {
          "type": "integer"
        },
        "gen_ai_response_id": {
          "type": "string"
        },
        "gen_ai_response_finish_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "gen_ai_usage_input_tokens": {
          "type": "integer"
        },
        "gen_ai_usage_output_tokens": {
          "type": "integer"
        },
        "gen_ai_tool_name": {
          "type": "string"
        },
        "gen_ai_tool_call_id": {
          "type": "string"
        },
