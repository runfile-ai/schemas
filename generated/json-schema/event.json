        "framework": {
          "type": "string",
          "enum": [
            "langgraph",
            "langgraph_js",
            "openai_agents",
            "openai_agents_js",
            "anthropic_claude",
            "anthropic_claude_js",
            "claude_agent_sdk",
            "mastra",
            "vercel_ai_sdk",
            "pydantic_ai",
            "crewai",
            "mcp_client",
            "otel_generic",
            "manual"
          ]
        },
        "framework_version": {
          "$ref": "#/definitions/SdkMetadata/properties/version"
        },
        "adapter": {
          "type": "string",
          "maxLength": 64
        },
        "host": {
          "type": "string",
          "maxLength": 256
        }
