{
  "$schema": "https://json-schema.org/draft/2019-09/schema#",
  "title": "ingest",
  "description": "Runfile ingest schemas. Source: src/ingest.ts (Zod). Do not edit by hand.",
  "$ref": "#/definitions/_RunfileBundle",
  "definitions": {
    "BatchSubmission": {
      "type": "object",
      "properties": {
        "batch_id": {
          "type": "string",
          "pattern": "^b_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "$ref": "#/definitions/RunCreateItem"
              },
              {
                "$ref": "#/definitions/RunUpdateItem"
              },
              {
                "$ref": "#/definitions/RunEndItem"
              },
              {
                "$ref": "#/definitions/EventItem"
              }
            ]
          },
          "minItems": 1,
          "maxItems": 100
        }
      },
      "required": [
        "batch_id",
        "items"
      ],
      "additionalProperties": false
    },
    "RunCreateItem": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "run_create"
        },
        "run": {
          "$ref": "#/definitions/RunSubmission"
        }
      },
      "required": [
        "type",
        "run"
      ],
      "additionalProperties": false
    },
    "RunUpdateItem": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "run_update"
        },
        "run_id": {
          "type": "string",
          "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "lifecycle_state": {
          "type": "string",
          "enum": [
            "active",
            "awaiting_human",
            "awaiting_webhook",
            "awaiting_schedule",
            "ended"
          ]
        },
        "triggered_by_event_id": {
          "type": "string",
          "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
        }
      },
      "required": [
        "type",
        "run_id",
        "lifecycle_state",
        "triggered_by_event_id"
      ],
      "additionalProperties": false
    },
    "RunEndItem": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "run_end"
        },
        "run_id": {
          "$ref": "#/definitions/RunUpdateItem/properties/run_id"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "failure",
            "incomplete",
            "abandoned"
          ]
        },
        "final_event_id": {
          "$ref": "#/definitions/RunUpdateItem/properties/triggered_by_event_id"
        }
      },
      "required": [
        "type",
        "run_id",
        "ended_at",
        "outcome"
      ],
      "additionalProperties": false
    },
    "EventItem": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "const": "event"
        },
        "event": {
          "$ref": "#/definitions/EventSubmission"
        }
      },
      "required": [
        "type",
        "event"
      ],
      "additionalProperties": false
    },
    "RunSubmission": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "run_id": {
          "$ref": "#/definitions/RunUpdateItem/properties/run_id"
        },
        "agent_identity": {
          "type": "string",
          "pattern": "^did:[a-z][a-z0-9]*:[A-Za-z0-9._:-]+$"
        },
        "conversation_id": {
          "type": "string",
          "maxLength": 256
        },
        "lifecycle_state": {
          "type": "string",
          "const": "active"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "delegated_from": {
          "type": "object",
          "properties": {
            "run_id": {
              "type": "string",
              "pattern": "^run_[0-9A-HJKMNP-TV-Z]{26}$"
            },
            "event_id": {
              "type": "string",
              "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
            }
          },
          "required": [
            "run_id"
          ],
          "additionalProperties": false
        },
        "handed_off_from": {
          "$ref": "#/definitions/RunSubmission/properties/delegated_from"
        },
        "scheduled_from": {
          "$ref": "#/definitions/RunSubmission/properties/delegated_from"
        },
        "invoked_by": {
          "$ref": "#/definitions/RunSubmission/properties/delegated_from"
        },
        "continued_from": {
          "$ref": "#/definitions/RunSubmission/properties/delegated_from"
        },
        "environment": {
          "type": "string",
          "enum": [
            "production",
            "staging",
            "development"
          ]
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "maxLength": 128
          },
          "propertyNames": {
            "pattern": "^[a-z][a-z0-9_]{0,31}$"
          },
          "maxProperties": 16
        },
        "redaction_policy_version": {
          "$ref": "#/definitions/RunSubmission/properties/schema_version"
        },
        "regulatory_scope_version": {
          "$ref": "#/definitions/RunSubmission/properties/schema_version"
        },
        "sdk_at_start": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string",
              "enum": [
                "runfile-py",
                "@runfile/sdk"
              ]
            },
            "version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-z0-9.-]+)?$"
            },
            "framework": {
              "type": "string",
              "enum": [
                "langgraph",
                "langgraph_js",
                "openai_agents",
                "openai_agents_js",
                "anthropic_claude",
                "anthropic_claude_js",
                "claude_agent_sdk",
                "mastra",
                "vercel_ai_sdk",
                "pydantic_ai",
                "crewai",
                "mcp_client",
                "otel_generic",
                "manual"
              ]
            },
            "framework_version": {
              "$ref": "#/definitions/RunSubmission/properties/sdk_at_start/properties/version"
            },
            "adapter": {
              "type": "string",
              "maxLength": 64
            },
            "host": {
              "type": "string",
              "maxLength": 256
            }
          },
          "required": [
            "name",
            "version",
            "framework"
          ],
          "additionalProperties": false
        },
        "prev_event_hash_intent": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "agent_identity",
        "lifecycle_state",
        "started_at",
        "redaction_policy_version"
      ],
      "additionalProperties": false
    },
    "EventSubmission": {
      "type": "object",
      "properties": {
        "schema_version": {
          "$ref": "#/definitions/RunSubmission/properties/schema_version"
        },
        "event_id": {
          "$ref": "#/definitions/RunUpdateItem/properties/triggered_by_event_id"
        },
        "run_id": {
          "$ref": "#/definitions/RunUpdateItem/properties/run_id"
        },
        "parent_event_id": {
          "anyOf": [
            {
              "$ref": "#/definitions/RunUpdateItem/properties/triggered_by_event_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "parallel_group_id": {
          "type": "string",
          "pattern": "^pg_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "wall_clock_source": {
          "type": "string",
          "enum": [
            "aws_time_sync",
            "ntp",
            "host_system",
            "unknown"
          ]
        },
        "sdk": {
          "$ref": "#/definitions/RunSubmission/properties/sdk_at_start"
        },
        "actor": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "agent",
                "human",
                "tool",
                "system"
              ]
            },
            "agent_identity": {
              "type": "string",
              "pattern": "^did:[a-z][a-z0-9]*:[A-Za-z0-9._:-]+$",
              "description": "DID-format identifier of the agent. Required when type=agent."
            },
            "human_principal": {
              "type": "string",
              "pattern": "^tok_[A-Za-z0-9]{16,64}$",
              "description": "Vault token identifying the human principal."
            },
            "delegation_chain": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 16,
              "default": []
            },
            "tool_id": {
              "type": "string",
              "pattern": "^tool:[a-z0-9_.-]+:[a-z0-9_.-]+$"
            },
            "tool_version_hash": {
              "type": "string",
              "pattern": "^sha256:[a-f0-9]{64}$"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        "action": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "graph_node_enter",
                "graph_node_exit",
                "llm_call",
                "llm_call_chunk",
                "tool_call",
                "tool_result",
                "tool_approval_requested",
                "tool_approval_granted",
                "tool_approval_denied",
                "state_read",
                "state_write",
                "decision",
                "run_create",
                "run_end",
                "run_suspend",
                "run_resume",
                "run_abandon",
                "delegate",
                "handoff",
                "schedule_task",
                "parallel_group_open",
                "parallel_group_close",
                "human_approval",
                "human_input",
                "policy_check",
                "anomaly_flag",
                "sdk_diagnostic"
              ]
            },
            "name": {
              "type": "string",
              "maxLength": 256
            },
            "outcome": {
              "type": "string",
              "enum": [
                "success",
                "failure",
                "partial",
                "timeout",
                "cancelled"
              ]
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "name"
          ],
          "additionalProperties": false
        },
        "subject": {
          "type": "object",
          "properties": {
            "resource_urn": {
              "type": "string",
              "pattern": "^urn:[a-z0-9][a-z0-9-]{0,31}:.+$",
              "maxLength": 512
            },
            "data_classification": {
              "type": "string",
              "enum": [
                "public",
                "internal",
                "confidential",
                "pii",
                "phi",
                "pci",
                "fci",
                "audit_of_audit"
              ]
            },
            "regulatory_tags": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9_]+$"
              },
              "maxItems": 32
            }
          },
          "additionalProperties": false
        },
        "model_ref": {
          "type": "object",
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "anthropic",
                "openai",
                "google",
                "aws_bedrock",
                "azure_openai",
                "ollama",
                "self_hosted",
                "other"
              ]
            },
            "model_id": {
              "type": "string",
              "maxLength": 128
            },
            "model_version_hash": {
              "$ref": "#/definitions/EventSubmission/properties/actor/properties/tool_version_hash"
            },
            "system_prompt_hash": {
              "$ref": "#/definitions/EventSubmission/properties/actor/properties/tool_version_hash"
            },
            "tools_hash": {
              "$ref": "#/definitions/EventSubmission/properties/actor/properties/tool_version_hash"
            },
            "input_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "output_tokens": {
              "type": "integer",
              "minimum": 0
            },
            "temperature": {
              "type": "number",
              "minimum": 0,
              "maximum": 2
            },
            "streaming": {
              "type": "boolean"
            }
          },
          "required": [
            "provider",
            "model_id"
          ],
          "additionalProperties": false
        },
        "decision": {
          "type": "object",
          "properties": {
            "outcome": {
              "type": "string",
              "enum": [
                "approved",
                "denied",
                "escalated",
                "deferred",
                "no_action",
                "custom"
              ]
            },
            "outcome_label": {
              "type": "string",
              "maxLength": 64
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "human_in_the_loop": {
              "type": "boolean"
            },
            "policy_thresholds_crossed": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 64
              },
              "maxItems": 16
            },
            "reversed_by_event": {
              "$ref": "#/definitions/RunSubmission/properties/delegated_from/properties/event_id"
            }
          },
          "required": [
            "outcome"
          ],
          "additionalProperties": false
        },
        "suspension_details": {
          "type": "object",
          "properties": {
            "reason": {
              "type": "string",
              "enum": [
                "awaiting_human_approval",
                "awaiting_human_input",
                "awaiting_webhook",
                "awaiting_schedule",
                "awaiting_external_system",
                "awaiting_subagent",
                "other"
              ]
            },
            "expected_resumer": {
              "type": "string"
            },
            "expected_resume_by": {
              "type": "string",
              "format": "date-time"
            },
            "detection_source": {
              "type": "string",
              "enum": [
                "framework_inferred",
                "customer_explicit",
                "derived"
              ]
            },
            "framework_signal": {
              "type": "object",
              "properties": {
                "framework": {
                  "type": "string",
                  "enum": [
                    "langgraph",
                    "openai_agents",
                    "claude_agent_sdk",
                    "vercel_ai_sdk",
                    "mcp",
                    "manual",
                    "otel"
                  ]
                },
                "signal_name": {
                  "type": "string",
                  "maxLength": 128
                },
                "signal_payload_hash": {
                  "$ref": "#/definitions/EventSubmission/properties/actor/properties/tool_version_hash"
                }
              },
              "additionalProperties": false
            }
          },
          "required": [
            "reason"
          ],
          "additionalProperties": false
        },
        "resume_details": {
          "type": "object",
          "properties": {
            "triggered_by": {
              "type": "string",
              "enum": [
                "human_approval_granted",
                "human_input_received",
                "webhook_received",
                "schedule_fired",
                "external_system_response",
                "subagent_completed",
                "manual_resume",
                "other"
              ]
            },
            "resumer_principal": {
              "$ref": "#/definitions/EventSubmission/properties/actor/properties/human_principal"
            },
            "suspension_duration_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "suspension_started_event_id": {
              "$ref": "#/definitions/RunSubmission/properties/delegated_from/properties/event_id"
            }
          },
          "required": [
            "triggered_by"
          ],
          "additionalProperties": false
        },
        "delegation_details": {
          "type": "object",
          "properties": {
            "delegated_run_id": {
              "$ref": "#/definitions/RunSubmission/properties/delegated_from/properties/run_id"
            },
            "delegated_agent_identity": {
              "$ref": "#/definitions/EventSubmission/properties/actor/properties/agent_identity"
            },
            "wait_for_completion": {
              "type": "boolean"
            },
            "framework_signal": {
              "type": "string",
              "enum": [
                "langgraph_subgraph",
                "openai_agents_as_tool",
                "claude_agent_sdk_subagent",
                "manual",
                "other"
              ]
            }
          },
          "required": [
            "delegated_run_id",
            "delegated_agent_identity"
          ],
          "additionalProperties": false
        },
        "handoff_details": {
          "type": "object",
          "properties": {
            "target_run_id": {
              "$ref": "#/definitions/RunSubmission/properties/delegated_from/properties/run_id"
            },
            "target_agent_identity": {
              "$ref": "#/definitions/EventSubmission/properties/actor/properties/agent_identity"
            },
            "handoff_reason": {
              "type": "string",
              "maxLength": 256
            },
            "framework_signal": {
              "type": "string",
              "enum": [
                "openai_agents_handoff",
                "langgraph_explicit",
                "manual",
                "other"
              ]
            }
          },
          "required": [
            "target_run_id",
            "target_agent_identity"
          ],
          "additionalProperties": false
        },
        "payload_ref": {
          "$ref": "#/definitions/PayloadSubmission"
        },
        "otel_attributes": {
          "type": "object",
          "properties": {
            "gen_ai_system": {
              "type": "string"
            },
            "gen_ai_operation_name": {
              "type": "string"
            },
            "gen_ai_provider_name": {
              "type": "string"
            },
            "gen_ai_request_model": {
              "type": "string"
            },
            "gen_ai_response_model": {
              "type": "string"
            },
            "gen_ai_request_temperature": {
              "type": "number"
            },
            "gen_ai_request_top_p": {
              "type": "number"
            },
            "gen_ai_request_max_tokens": {
              "type": "integer"
            },
            "gen_ai_response_id": {
              "type": "string"
            },
            "gen_ai_response_finish_reasons": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "gen_ai_usage_input_tokens": {
              "type": "integer"
            },
            "gen_ai_usage_output_tokens": {
              "type": "integer"
            },
            "gen_ai_tool_name": {
              "type": "string"
            },
            "gen_ai_tool_call_id": {
              "type": "string"
            },
            "gen_ai_agent_id": {
              "type": "string"
            },
            "gen_ai_agent_name": {
              "type": "string"
            },
            "gen_ai_agent_description": {
              "type": "string"
            },
            "gen_ai_conversation_id": {
              "type": "string"
            },
            "extra": {
              "type": "object",
              "additionalProperties": {
                "type": [
                  "string",
                  "number",
                  "boolean"
                ]
              }
            }
          },
          "additionalProperties": false
        },
        "redaction_policy_version": {
          "$ref": "#/definitions/RunSubmission/properties/schema_version"
        },
        "regulatory_scope_version": {
          "$ref": "#/definitions/RunSubmission/properties/schema_version"
        },
        "anomaly_flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "missing_ambient_context",
                  "chain_break",
                  "out_of_order_arrival",
                  "model_version_drift",
                  "unknown_agent_identity",
                  "data_classification_mismatch",
                  "policy_threshold_without_hitl",
                  "unauthorized_tool_invocation",
                  "redaction_policy_mismatch",
                  "schema_version_warning",
                  "agent_identity_mismatch_with_run",
                  "suspension_sla_exceeded",
                  "apparent_crash_detected",
                  "active_duration_exceeds_threshold",
                  "framework_signal_unrecognised",
                  "otel_attribute_missing",
                  "delegation_loop_detected"
                ]
              },
              "severity": {
                "type": "string",
                "enum": [
                  "info",
                  "warning",
                  "error",
                  "critical"
                ]
              },
              "detail": {
                "type": "string",
                "maxLength": 1024
              }
            },
            "required": [
              "code",
              "severity"
            ],
            "additionalProperties": false
          },
          "maxItems": 32
        },
        "environment": {
          "$ref": "#/definitions/RunSubmission/properties/environment"
        },
        "labels": {
          "$ref": "#/definitions/RunSubmission/properties/labels"
        },
        "prev_event_hash_intent": {
          "$ref": "#/definitions/RunSubmission/properties/prev_event_hash_intent"
        }
      },
      "required": [
        "schema_version",
        "event_id",
        "run_id",
        "parent_event_id",
        "captured_at",
        "wall_clock_source",
        "sdk",
        "actor",
        "action",
        "redaction_policy_version",
        "prev_event_hash_intent"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "llm_call"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "model_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "decision"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "decision"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "run_suspend"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "suspension_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "run_resume"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "resume_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "delegate"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "delegation_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "properties": {
                  "kind": {
                    "const": "handoff"
                  }
                }
              }
            }
          },
          "then": {
            "required": [
              "handoff_details"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "actor": {
                "properties": {
                  "type": {
                    "const": "agent"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "actor": {
                "required": [
                  "agent_identity"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "actor": {
                "properties": {
                  "type": {
                    "const": "tool"
                  }
                }
              }
            }
          },
          "then": {
            "properties": {
              "actor": {
                "required": [
                  "tool_id",
                  "tool_version_hash"
                ]
              }
            }
          }
        }
      ]
    },
    "PayloadSubmission": {
      "type": "object",
      "properties": {
        "s3_uri_intent": {
          "type": "string",
          "maxLength": 1024
        },
        "sha256": {
          "$ref": "#/definitions/RunSubmission/properties/prev_event_hash_intent"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 67108864
        },
        "encryption": {
          "type": "object",
          "properties": {
            "algorithm": {
              "type": "string",
              "const": "aes-256-gcm"
            },
            "data_key_wrapped": {
              "type": "string",
              "maxLength": 4096
            },
            "key_id": {
              "type": "string",
              "maxLength": 256
            },
            "nonce": {
              "type": "string",
              "maxLength": 64
            }
          },
          "required": [
            "algorithm",
            "data_key_wrapped",
            "nonce"
          ],
          "additionalProperties": false
        },
        "content_type": {
          "type": "string",
          "enum": [
            "application/json",
            "text/plain",
            "application/vnd.runfile.llm-request+json",
            "application/vnd.runfile.llm-response+json",
            "application/vnd.runfile.tool-call+json",
            "application/vnd.runfile.tool-result+json",
            "application/vnd.runfile.state-snapshot+json",
            "application/vnd.runfile.framework-signal+json"
          ]
        },
        "redaction_applied": {
          "type": "object",
          "properties": {
            "redacted_classes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 32
            },
            "tokenized_classes": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "maxItems": 32
            },
            "classifier_version": {
              "type": "string",
              "pattern": "^\\d+\\.\\d+\\.\\d+$"
            }
          },
          "additionalProperties": false
        },
        "ciphertext_base64": {
          "type": "string",
          "maxLength": 7340032
        }
      },
      "required": [
        "sha256",
        "size_bytes",
        "encryption",
        "ciphertext_base64"
      ],
      "additionalProperties": false
    },
